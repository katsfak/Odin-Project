<% layout('../layout') -%>
<section class="split">
  <div>
    <h1>Your folders</h1>
    <% if (folders.length === 0) { %>
    <p>No folders yet. Create one to get started.</p>
    <% } else { %>
    <ul class="folder-list">
      <% folders.forEach((folder) => { %>
      <li>
        <a href="/folders/<%= folder.id %>"><%= folder.name %></a>
        <span><%= folder._count.files %> files</span>
      </li>
      <% }) %>
    </ul>
    <% } %>
  </div>

  <div class="card">
    <h2>Create folder</h2>
    <form method="POST" action="/folders">
      <label>Name
        <input type="text" name="name" value="<%= form ? form.name : '' %>" required />
      </label>
      <button type="submit">Create</button>
    </form>
    <% if (errors && errors.length) { %>
    <ul class="errors">
      <% errors.forEach((err) => { %>
      <li><%= err.msg %></li>
      <% }) %>
    </ul>
    <% } %>
  </div>
</section>
