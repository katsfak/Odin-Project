<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="brand">File Uploader</div>
      <nav>
        <a href="/">Home</a>
        <% if (currentUser) { %>
        <a href="/folders">Folders</a>
        <form class="inline" action="/logout?_method=POST" method="POST">
          <button type="submit">Logout</button>
        </form>
        <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
        <% } %>
      </nav>
    </header>

    <main>
      <% if (success && success.length) { %>
      <div class="flash success"><%= success[0] %></div>
      <% } %>
      <% if (error && error.length) { %>
      <div class="flash error"><%= error[0] %></div>
      <% } %>
      <% if (shareLink && shareLink.length) { %>
      <div class="flash info">Share link: <a href="<%= shareLink[0] %>"><%= shareLink[0] %></a></div>
      <% } %>
      <%- body %>
    </main>
  </body>
</html>
