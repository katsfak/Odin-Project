<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <main>
      <h1><%= title %></h1>
      <p><a href="/new">Create a new message</a></p>

      <% messages.forEach((message, index) => { %>
      <article>
        <h2><%= message.user %></h2>
        <p><%= message.text %></p>
        <small><%= message.added %></small>
        <p><a href="/messages/<%= index %>">Open</a></p>
      </article>
      <% }); %>
    </main>
  </body>
</html>
