<% layout('../layout') -%>
<section class="card">
  <h1>Sign in</h1>
  <form method="POST" action="/login">
    <label>Email
      <input type="email" name="email" value="<%= form.email || '' %>" required />
    </label>
    <label>Password
      <input type="password" name="password" required />
    </label>
    <button type="submit">Login</button>
  </form>
  <% if (errors && errors.length) { %>
  <ul class="errors">
    <% errors.forEach((err) => { %>
    <li><%= err.msg %></li>
    <% }) %>
  </ul>
  <% } %>
</section>
