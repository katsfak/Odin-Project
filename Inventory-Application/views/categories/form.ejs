<%- include('../partials/header') %>

<section class="panel">
  <h1><%= heading %></h1>

  <%- include('../partials/errors', { errors }) %>

  <form action="<%= action %>" method="POST" class="stack-form">
    <label for="name">Name</label>
    <input id="name" name="name" type="text" value="<%= category.name || '' %>" required />

    <label for="description">Description</label>
    <textarea id="description" name="description" rows="4"><%= category.description || '' %></textarea>

    <% if (requiresAdminPassword) { %>
      <label for="adminPassword">Admin password</label>
      <input id="adminPassword" name="adminPassword" type="password" required />
    <% } %>

    <button type="submit">Save Category</button>
  </form>
</section>

<%- include('../partials/footer') %>
