<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error - Members Only</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <nav class="navbar">
      <div class="container">
        <a href="/" class="logo">Members Only</a>
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
        </ul>
      </div>
    </nav>

    <main class="container">
      <div class="error-container">
        <h1>Error <%= error.status || 500 %></h1>
        <p><%= error.message || 'Something went wrong' %></p>
        <a href="/" class="btn-primary">Go Home</a>
      </div>
    </main>

    <footer>
      <div class="container">
        <p>&copy; 2026 Members Only. Built with Express & PostgreSQL.</p>
      </div>
    </footer>
  </body>
</html>
